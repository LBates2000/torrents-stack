# User/group
PUID=1000
PGID=1000

# Time zone
TZ=Etc/UTC

# DNS used by wireguard, jackett, and flaresolverr
DNS1=8.8.8.8
DNS2=1.1.1.1

# Published ports
QBITTORRENT_WEBUI_PORT=8090
QBITTORRENT_TORRENTING_PORT=6881
JACKETT_PORT=9117
FLARESOLVERR_PORT=8191
WIREGUARD_SERVERPORT=51820

# WireGuard basics
WIREGUARD_SERVERURL=example.com
WIREGUARD_PEERS=1
WIREGUARD_PEERDNS=auto
WIREGUARD_ALLOWEDIPS=0.0.0.0/0
WIREGUARD_LOG_CONFS=false

# Optional: URL used by wireguard healthcheck external IP verification
WIREGUARD_IP_CHECK_URL=https://api.ipify.org
